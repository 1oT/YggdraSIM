{
  "schema": "scp03-live-1",
  "description": "Per-command stdin scripts for the SCP03 admin shell. Default backend is the simulated card; the runner can also drive a real PC/SC reader when SCP03_LIVE_BACKEND=reader.",
  "reader_policy": {
    "comment": "Reader-mode gating. 'auth' tests authenticate against the card's Security Domain — every key mismatch increments the SD lockout counter and 3 misses can brick the SD. 'write' tests modify card state. Tests not listed here run by default (read-only / offline / local-only).",
    "auth": [
      "AUTH-SD",
      "SCP03-SD",
      "SCP02-SD",
      "KEYS",
      "LOGOUT",
      "LIST",
      "LIST-IOT",
      "GET-IOT",
      "APPS",
      "PKGS",
      "SD",
      "STORE-DATA",
      "LOCK",
      "UNLOCK",
      "DEL",
      "SCAN",
      "DUMP-FS",
      "VALIDATE",
      "ARR",
      "CERT-INFO",
      "EXPORT-EUICC",
      "EXPORT-KEYBAG",
      "PROFILE-DIFF",
      "REPORT",
      "MANAGE-PROFILE",
      "GET-DATA",
      "PUT-KEY",
      "SET-STATUS",
      "MANAGE-CHANNEL",
      "WIZARD",
      "FS-ADMIN",
      "MANAGE-PIN",
      "RUN-AUTH",
      "STK",
      "OTA"
    ],
    "write": [
      "UPDATE"
    ]
  },
  "snapshot_files": [
    "Workspace/SCP03/aid.txt",
    "Workspace/SCP03/keys.ini",
    "Workspace/SCP03/binds.json",
    "Workspace/SCP03/fids.txt",
    "state/yggdrasim.sqlite3",
    "state/yggdrasim.sqlite3-wal",
    "state/yggdrasim.sqlite3-shm"
  ],
  "tests": [
    {
      "name": "AUTH-SD",
      "script": "AUTH-SD.in.txt",
      "category": "session",
      "expected_sw": ["9000"],
      "expected_substrings": [
        "SCP03 Authenticated",
        "Level 0x33",
        "KVN 0x30"
      ],
      "notes": "Legacy alias for SCP03-SD."
    },
    {
      "name": "SCP03-SD",
      "script": "SCP03-SD.in.txt",
      "category": "session",
      "expected_sw": ["9000"],
      "expected_substrings": ["SCP03 Authenticated", "KVN 0x30"]
    },
    {
      "name": "SCP02-SD",
      "script": "SCP02-SD.in.txt",
      "category": "session",
      "expected_sw_any": ["9000", "6A82", "6985", "6A88", "6D00"],
      "expected_substrings": ["SCP02 simulated session activated"],
      "tolerate_failure": true,
      "notes": "Simulator implements a plaintext SCP02 fake session for tooling parity."
    },
    {
      "name": "RESET",
      "script": "RESET.in.txt",
      "category": "session",
      "expected_substrings": ["Resetting card", "Reset Successful"],
      "tolerate_failure": false
