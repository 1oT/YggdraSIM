# openssl x509 extfile params
extensions = extend
# This prevent the user to be prompted for values
prompt = no

[extend] # openssl extensions
authorityKeyIdentifier=keyid,issuer

subjectKeyIdentifier=hash

subjectAltName = RID:2.999.221

keyUsage = critical, keyCertSign, cRLSign

# Missaligment in SGP.26 v3.0.1 files (this value is correct and is updated in SGP.26v3.0.2 spec) (not critical)
certificatePolicies = 2.23.146.1.2.1.0.0.1

basicConstraints = critical,CA:TRUE, pathlen:0

crlDistributionPoints=URI:http://ci.test.example.com/CRL-1.crl, URI:http://ci.test.example.com/CRL-2.crl

