# Hidden local metadata, SCM metadata, and caches not needed inside the image.
.*
*-transcripts/
venv/

# Python bytecode and local caches.
__pycache__/
*.pyc
*.pyo
*.swp

# Sensitive or operator-only runtime state. The image creates a fresh
# ``/opt/YggdraSIM-data`` root on first boot; host-side state must not
# bleed in at build time.
YggdraSIM-data/
Workspace/
state/
Latjo/
Legal/
*.db
*.sqlite3
*.jsonl
*.pem
*.der
*.crt
*.csr
*.key
*.p8
*.p12
*.pfx
*.jks
*.keystore
*.srl
*.secret
*.secrets
eim_last_response.bin
eim_last_response_hex.txt
SCP11/eim_local/eim_last_response.bin
SCP11/eim_local/eim_last_response_hex.txt
SCP11/eim_local/eim_response_log.jsonl
SCP11/eim_local/eim_poll_audit.sqlite3
SCP11/eim_local/eim_runtime_state.json
SCP11/local_access/debug/

# Developer capture / scratch trees that can balloon context size.
trace/
.profilepackage-cache/
docs/
scripts/docs/
.pytest_chunk_log*.txt
.pytest_last_run*.log
.pytest_pre_log*.txt
.unittest_last_run*.log
.run_*.txt
.smoke_*
.tshark_*
.tmuxshark*
.live_*pdml*
.active_env_exact_pdml*
.direct_*_probe*
.sudo_pdml_probe*
.user_pdml_probe*
.hil_tui_*
.hil_decode_tui_probe*

# Build artefacts that get regenerated inside the image.
build/
dist/
site/
yggdrasim.egg-info/

# Optional upstream checkouts that are gitignored at the repo level. They
# are NOT vendored — ``pysim/`` is cloned from
# https://gitlab.com/osmocom/pysim.git by operators who need the SAIP
# ASN.1 compile path or the SCP11-local flows; ``pyscard/`` only ever
# appears as a stale virtualenv and must never reach the image. Both are
# excluded from the build context to keep layers small.
pysim/
pyscard/

# Runtime plugin implementations are local-only and must not enter the
# Docker build context. The public loader contract remains in source docs.
plugins/
tests/plugins/

# Documentation output and ephemeral reports.
reports/
YggdraSIM.md
reference_test_profile.transcode.*
demo.der
